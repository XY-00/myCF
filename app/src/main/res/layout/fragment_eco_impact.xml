<?xml version="1.0" encoding="utf-8"?>
<!-- 👑 外层 FrameLayout 牢牢锁死树叶大背景底图 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 1. 锁死在底层的全屏大背景图 -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/app_background"
        android:scaleType="centerCrop" />

    <!-- 2. 滑动内容层（背景透明） -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- 顶部的 Eco Impact 绿色导航栏 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#4A7A68"
                android:text="Eco Impact"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>

            <!-- ==================== CARD 1: Farmer 个人荣誉名片卡 ==================== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F4F3E3"
                app:strokeColor="#111111"
                app:strokeWidth="1.5dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- 上半部：头像与身份 ID -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <!-- 圆形黑细边框头像层 -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            app:cardCornerRadius="27dp"
                            app:strokeColor="#111111"
                            app:strokeWidth="1.5dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="🧑‍🌾"
                                android:textSize="28sp"
                                android:gravity="center"
                                android:background="#E2F0D9"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Farmer: Lee Xin Yi"
                                android:textColor="#111111"
                                android:textStyle="bold"
                                android:textSize="18sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="UserID: FARM0027"
                                android:textColor="#222222"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 中间细黑线分割线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:background="#111111"
                        android:layout_marginBottom="12dp"/>

                    <!-- 下半部：等级圆章与全服排名 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- 带有黑外圈的标志性大“A”等级绿章 -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardCornerRadius="24dp"
                            app:cardBackgroundColor="#8CB39D"
                            app:strokeColor="#111111"
                            app:strokeWidth="1.5dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="A"
                                android:textColor="#111111"
                                android:textStyle="bold"
                                android:textSize="24sp"
                                android:gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Eco Friendly Grade"
                                android:textColor="#111111"
                                android:textStyle="bold"
                                android:textSize="16sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Top 5% of Farmers"
                                android:textColor="#222222"
                                android:textStyle="bold"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==================== 2. 中间横向并排的 3 个数据小徽章 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- 徽章 1: Total Carbon Saved -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#F4F3E3"
                    app:strokeColor="#111111"
                    app:strokeWidth="1.5dp"
                    app:cardElevation="0dp">
