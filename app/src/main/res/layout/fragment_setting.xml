<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/app_background"
        android:scaleType="centerCrop" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tv_setting_title"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#4A7A68"
                android:text="Setting"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#F4F3E3"
                app:strokeColor="#111111"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏱️"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Operation Mode Controls"
                            android:textColor="#2A5C3A"
                            android:textStyle="bold"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginBottom="14dp"
                        app:cardCornerRadius="8dp"
                        app:strokeColor="#111111"
                        app:strokeWidth="1.5dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">
                            <TextView
                                android:id="@+id/btn_mode_full"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Full Auto"
                                android:gravity="center"
                                android:textColor="#111111"
                                android:textStyle="bold"
                                android:textSize="15sp"/>
                            <View android:layout_width="1.5dp" android:layout_height="match_parent" android:background="#111111"/>
                            <TextView
                                android:id="@+id/btn_mode_semi"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Semi Auto"
                                android:gravity="center"
                                android:textColor="#111111"
                                android:textStyle="bold"
                                android:textSize="15sp"/>
                            <View android:layout_width="1.5dp" android:layout_height="match_parent" android:background="#111111"/>
                            <TextView
                                android:id="@+id/btn_mode_power"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Power Save"
                                android:gravity="center"
                                android:textColor="#111111"
                                android:textStyle="bold"
                                android:textSize="15sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#F4F3E3"
                        app:strokeColor="#111111"
                        app:strokeWidth="1.5dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🎛️  Carbon Red-line Target Controls"
                                    android:textColor="#111111"
                                    android:textSize="12sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:id="@+id/tv_seekbar_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="59.0 %"
                                    android:textColor="#111111"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:layout_alignParentEnd="true"/>
                            </RelativeLayout>
                            <SeekBar
                                android:id="@+id/seekbar_carbon"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:max="1000"
                                android:progress="590"
                                android:progressTint="#7A9C78"
                                android:thumbTint="#7A9C78"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F4F3E3"
                app:strokeColor="#111111"
                app:strokeWidth="1.5dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧  Water Controls"
                        android:textColor="#2A5C3A"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginBottom="10dp"
                        app:cardCornerRadius="23dp"
                        app:cardBackgroundColor="#F4F3E3"
                        app:strokeColor="#111111"
                        app:strokeWidth="1.5dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Max Watering Duration"
                                android:textColor="#111111"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="145dp"
                                android:layout_height="40dp"
                                app:hintEnabled="false"
                                app:boxStrokeWidth="0dp"
                                app:boxStrokeWidthFocused="0dp"
                                app:endIconTint="#111111">
                                <AutoCompleteTextView
                                    android:id="@+id/auto_duration"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@android:color/transparent"
                                    android:inputType="none"
                                    android:text="10 sec (Recommand)"
                                    android:textColor="#111111"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:padding="0dp"
                                    android:gravity="center_vertical|end"/>
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        app:cardCornerRadius="23dp"
                        app:cardBackgroundColor="#F4F3E3"
                        app:strokeColor="#111111"
                        app:strokeWidth="1.5dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Watering Interval"
                                android:textColor="#111111"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="145dp"
                                android:layout_height="40dp"
                                app:hintEnabled="false"
                                app:boxStrokeWidth="0dp"
                                app:boxStrokeWidthFocused="0dp"
                                app:endIconTint="#111111">
                                <AutoCompleteTextView
                                    android:id="@+id/auto_interval"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@android:color/transparent"
                                    android:inputType="none"
                                    android:text="10 min"
                                    android:textColor="#111111"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:padding="0dp"
                                    android:gravity="center_vertical|end"/>
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F4F3E3"
                app:strokeColor="#111111"
                app:strokeWidth="1.5dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📷"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live Vision Setting"
                            android:textColor="#2A5C3A"
                            android:textStyle="bold"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginBottom="10dp"
                        app:cardCornerRadius="23dp"
                        app:cardBackgroundColor="#F4F3E3"
                        app:strokeColor="#111111"
                        app:strokeWidth="1.5dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Capture Frequency"
                                android:textColor="#111111"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="145dp"
                                android:layout_height="40dp"
                                app:hintEnabled="false"
                                app:boxStrokeWidth="0dp"
                                app:boxStrokeWidthFocused="0dp"
                                app:endIconTint="#111111">
                                <AutoCompleteTextView
                                    android:id="@+id/auto_freq"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@android:color/transparent"
                                    android:inputType="none"
                                    android:text="1 Hours"
                                    android:textColor="#111111"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:padding="0dp"
                                    android:gravity="center_vertical|end"/>
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        app:cardCornerRadius="23dp"
                        app:cardBackgroundColor="#F4F3E3"
                        app:strokeColor="#111111"
                        app:strokeWidth="1.5dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Image Quality"
                                android:textColor="#111111"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="145dp"
                                android:layout_height="40dp"
                                app:hintEnabled="false"
                                app:boxStrokeWidth="0dp"
                                app:boxStrokeWidthFocused="0dp"
                                app:endIconTint="#111111">
                                <AutoCompleteTextView
                                    android:id="@+id/auto_quality"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@android:color/transparent"
                                    android:inputType="none"
                                    android:text="Medium"
                                    android:textColor="#111111"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:padding="0dp"
                                    android:gravity="center_vertical|end"/>
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F4F3E3"
                app:strokeColor="#111111"
                app:strokeWidth="1.5dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manual Override Controls"
                            android:textColor="#AA2222"
                            android:textStyle="bold"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tray_manual_mode"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginBottom="10dp"
                        app:cardCornerRadius="22dp"
                        app:cardBackgroundColor="#F4F3E3"
                        app:strokeColor="#111111"
                        app:strokeWidth="1.5dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Enable Manual Mode"
                                android:textColor="#111111"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                            <Switch
                                android:id="@+id/switch_manual"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumbTint="#111111"
                                android:trackTint="#DCDCDC"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tray_pump_control"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        app:cardCornerRadius="22dp"
                        app:cardBackgroundColor="#F4F3E3"
                        app:strokeColor="#111111"
                        app:strokeWidth="1.5dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Water Pump Control"
                                android:textColor="#111111"
                                android:textSize="15sp"
                                android:textStyle="bold"/>

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btn_pump"
                                android:layout_width="115dp"
                                android:layout_height="28dp"
                                app:cardCornerRadius="14dp"
                                app:cardBackgroundColor="#C5C2E2"
                                app:strokeColor="#111111"
                                app:strokeWidth="1.5dp"
                                app:cardElevation="0dp"
                                android:clickable="true"
                                android:focusable="true">
                                <TextView
                                    android:id="@+id/btn_pump_text"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="Activate Pump"
                                    android:textColor="#111111"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:gravity="center"/>
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_logout_card"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#B4C794"
                app:strokeColor="#111111"
                app:strokeWidth="1.5dp"
                app:cardElevation="4dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="LOG OUT"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</FrameLayout>