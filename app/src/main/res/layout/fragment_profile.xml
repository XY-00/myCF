<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/app_background"
        android:scaleType="centerCrop" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#4A7A68"
                android:text="Plant Profile"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F4F3E3"
                app:strokeColor="#111111"
                app:strokeWidth="1.5dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeColor="#111111"
                        app:strokeWidth="1.2dp"
                        app:cardElevation="0dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="🥬"
                            android:textSize="70sp"
                            android:gravity="center"/>
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Common Name"
                            android:textColor="#555555"
                            android:textSize="11sp"
                            android:textStyle="italic"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bok Choy"
                            android:textColor="#111111"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scientific Name"
                            android:textColor="#555555"
                            android:textSize="11sp"
                            android:textStyle="italic"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Brassica rapa chinensis"
                            android:textColor="#111111"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Variety"
                            android:textColor="#555555"
                            android:textSize="11sp"
                            android:textStyle="italic"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Baby Bok Choy"
                            android:textColor="#111111"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginBottom="10dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📅"
                                android:textSize="18sp"
                                android:layout_marginEnd="6dp"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Age / Days Since Planting"
                                    android:textColor="#555555"
                                    android:textSize="10sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="30 Days"
                                    android:textColor="#111111"
                                    android:textStyle="bold"
                                    android:textSize="14sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Planted: 11/1/2026"
                                    android:textColor="#666666"
                                    android:textSize="10sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F4F3E3"
                app:strokeColor="#111111"
                app:strokeWidth="1.5dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Physiological Moisture Benchmarks"
                        android:textColor="#2A5C3A"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            app:cardCornerRadius="8dp"
                            app:cardBackgroundColor="#E2F0D9"
                            app:strokeColor="#2A5C3A"
                            app:strokeWidth="1.2dp"
                            app:cardElevation="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="8dp"
                                android:gravity="center">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🟢 Field Capacity"
                                    android:textColor="#2A5C3A"
                                    android:textSize="10sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="75 %"
                                    android:textColor="#111111"
                                    android:textStyle="bold"
                                    android:textSize="18sp"
                                    android:layout_marginTop="4dp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="moisture level maximum plant\nhealth and growth"
                                    android:textColor="#555555"
                                    android:textSize="7sp"
                                    android:gravity="center"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            app:cardCornerRadius="8dp"
                            app:cardBackgroundColor="#FFF2CC"
                            app:strokeColor="#B27A23"
                            app:strokeWidth="1.2dp"
                            app:cardElevation="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="8dp"
                                android:gravity="center">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🟡 Carbon Safe Line"
                                    android:textColor="#B27A23"
                                    android:textSize="10sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="59 %"
                                    android:textColor="#111111"
                                    android:textStyle="bold"
                                    android:textSize="18sp"
                                    android:layout_marginTop="4dp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="irrigation on before reaching\nthis point"
                                    android:textColor="#555555"
                                    android:textSize="7sp"
                                    android:gravity="center"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp"
                            app:cardBackgroundColor="#FCE4D6"
                            app:strokeColor="#C0504D"
                            app:strokeWidth="1.2dp"
                            app:cardElevation="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="8dp"
                                android:gravity="center">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔴 Wilting Point"
                                    android:textColor="#C0504D"
                                    android:textSize="10sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="45 %"
                                    android:textColor="#111111"
                                    android:textStyle="bold"
                                    android:textSize="18sp"
                                    android:layout_marginTop="4dp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="plant cannot recover moisture"
                                    android:textColor="#555555"
                                    android:textSize="7sp"
                                    android:gravity="center"
                                    android:layout_marginTop="10dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="4dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="45%" android:textColor="#111111" android:textStyle="bold" android:textSize="11sp" android:layout_marginStart="100dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="59%" android:textColor="#111111" android:textStyle="bold" android:textSize="11sp" android:layout_centerHorizontal="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="75%" android:textColor="#111111" android:textStyle="bold" android:textSize="11sp" android:layout_alignParentEnd="true" android:layout_marginEnd="60dp"/>
                        </RelativeLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="14dp"
                            app:cardCornerRadius="7dp"
                            app:strokeColor="#111111"
                            app:strokeWidth="1.2dp"
                            app:cardElevation="0dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/white"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F4F3E3"
                app:strokeColor="#111111"
                app:strokeWidth="1.5dp"
                app:cardElevation="3dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tv_history_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Growth History"
                        android:textColor="#2A5C3A"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:id="@+id/layout_pics"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:orientation="horizontal"
                        android:layout_below="@id/tv_history_title"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardCornerRadius="8dp" app:strokeColor="#111111" app:strokeWidth="1dp"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="🌱 Stage 1" android:gravity="center" android:textSize="11sp" android:background="#FFFFFF"/></com.google.android.material.card.MaterialCardView>
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardCornerRadius="8dp" app:strokeColor="#111111" app:strokeWidth="1dp"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="🌿 Stage 2" android:gravity="center" android:textSize="11sp" android:background="#FFFFFF"/></com.google.android.material.card.MaterialCardView>
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" app:cardCornerRadius="8dp" app:strokeColor="#111111" app:strokeWidth="1dp"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="🥬 Stage 3" android:gravity="center" android:textSize="11sp" android:background="#FFFFFF"/></com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="75dp"
                        android:layout_height="24dp"
                        android:layout_below="@id/layout_pics"
                        android:layout_alignParentEnd="true"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#F4F3E3"
                        app:strokeColor="#111111"
                        app:strokeWidth="1.2dp"
                        app:cardElevation="0dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="View all"
                            android:textColor="#111111"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:gravity="center"/>
                    </com.google.android.material.card.MaterialCardView>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F4F3E3"
                app:strokeColor="#111111"
                app:strokeWidth="1.5dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈 Predicted Water Requirements"
                        android:textColor="#2A5C3A"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="#FCFDF9" app:strokeColor="#111111" app:strokeWidth="1.2dp" app:cardElevation="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="8dp" android:gravity="center"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Daily pump" android:textColor="#555555" android:textSize="10sp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="180 ml" android:textColor="#111111" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="4dp"/></LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="#FCFDF9" app:strokeColor="#111111" app:strokeWidth="1.2dp" app:cardElevation="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="8dp" android:gravity="center"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weekly Total" android:textColor="#555555" android:textSize="10sp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.26 L" android:textColor="#111111" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="4dp"/></LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" app:cardCornerRadius="8dp" app:cardBackgroundColor="#FCFDF9" app:strokeColor="#111111" app:strokeWidth="1.2dp" app:cardElevation="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="8dp" android:gravity="center"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Irrigation Rules" android:textColor="#555555" android:textSize="10sp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4-5 / week" android:textColor="#111111" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="4dp"/></LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</FrameLayout>